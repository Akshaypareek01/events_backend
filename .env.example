PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/yoga-event
WEB_ORIGIN=http://localhost:3000

# Auth (use a long random string in production)
JWT_SECRET=change-me-in-production

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret from Razorpay dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# Email — prefer AWS SES SMTP for all app mail
SES_SMTP_ENDPOINT=
SES_SMTP_PORT=587
# Optional; use "true" only if using port 465 with implicit TLS
# SES_SMTP_SECURE=false
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
# Must be a verified identity in SES (same region as endpoint)
EMAIL_FROM=

# Fallback generic SMTP (only if SES vars above are unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: disable daily reminder cron
# REMINDER_CRON=false
# CRON_TZ=Asia/Kolkata

# Seed script only
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=changeme
