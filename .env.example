# Copy to .env and fill in. Do not commit .env.
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/yoga-event
# Comma-separated. Production must include every frontend origin (scheme + host + port) or the browser blocks API calls.
# Example: WEB_ORIGIN=http://localhost:3000,https://www.samsarawellness.in,https://samsarawellness.in
WEB_ORIGIN=http://localhost:3000

# Required in production: long random string (32+ chars), not the dev default
JWT_SECRET=

# Behind nginx/ALB/Cloudflare — use real client IP for rate limits
# TRUST_PROXY=1

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# AWS SES (or leave unset and use legacy SMTP below)
SES_SMTP_ENDPOINT=
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
SES_SMTP_PORT=587
EMAIL_FROM=

# Legacy SMTP (if not using SES)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

REMINDER_CRON=true

# Optional: admin seed (scripts/seed.ts)
# ADMIN_SEED_EMAIL=
# ADMIN_SEED_PASSWORD=
